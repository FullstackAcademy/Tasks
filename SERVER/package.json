{
  "name": "taskflow-server",
  "version": "1.0.0",
  "description": "TaskFlow API",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "prisma migrate deploy && node index.js",
    "dev": "nodemon index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "test": "vitest"
  },
  "dependencies": {
    "express": "5.2.1",
    "prisma": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "pg": "8.21.0",
    "bcrypt": "6.0.0",
    "jsonwebtoken": "9.0.3",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "node-cron": "4.2.1",
    "googleapis": "173.0.0",
    "ics": "3.12.0"
  },
  "devDependencies": {
    "vitest": "4.1.8",
    "supertest": "7.2.2",
    "nodemon": "3.1.14"
  }
}